{%- liquid
  assign first_block = section.blocks | first
  if first_block != blank
    assign first_block_image = first_block.settings.image
    if first_block.type == 'video'
      assign first_block_image = first_block.settings.video.preview_image | default: first_block.settings.cover_image
    endif

    assign first_block_image_mobile = first_block.settings.image_mobile | default: first_block_image
    if first_block.type == 'video'
      assign first_block_image_mobile = first_block.settings.video_mobile.preview_image | default: first_block.settings.cover_image_mobile
    endif
  endif
-%}
<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    {%- if first_block_image != blank and section.settings.image_height == 'adapt' %}
      --ratio-percent: {{ 1 | divided_by: first_block_image.aspect_ratio | times: 100 }}%;
    {% endif -%}
  }

  {%- if first_block_image_mobile != blank and section.settings.image_height_mobile == 'adapt' %}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --ratio-percent: {{ 1 | divided_by: first_block_image_mobile.aspect_ratio | times: 100 }}%;
      }
    }
  {% endif -%}

  /* Per-block heading/button positioning (3x3 grid over the slide) */
  /* The nav must fill the slide height; the theme has no flex-1/min-h-0 utility. */
  .slideshow-content:has(.slideshow-word--grid) { display: flex; flex-direction: column; height: 100%; }
  .slideshow-words:has(.slideshow-word--grid) {
    grid-template: minmax(0, 1fr) / minmax(0, 1fr);
    flex: 1 1 0;
    min-height: 0;
  }
  .slideshow-word--grid {
    grid-area: 1 / 1;
    container-type: inline-size;   /* enables cqw width (% of the slide) */
    display: grid;
    width: 100%;
    height: 100%;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
    grid-template-areas: "top" "middle" "bottom";
  }
  /* Heading width = % of the slide via the --heading-w container-width var */
  .slideshow-pos { display: flex; flex-direction: column; gap: var(--sp-6); max-width: var(--heading-w, 100cqw); }
  .slideshow-pos .banner__box { min-width: 0 !important; max-width: none !important; width: 100%; }
  /* Body text passage under the heading */
  .slideshow-text { font-size: var(--text-fs, 1rem); line-height: 1.5; opacity: 0.95; }
  .slideshow-pos .slideshow-text,
  .slideshow-pos .slideshow-text :is(p, span, a, em, strong, li, div) {
    font-family: var(--block-text-font, var(--font-body-family)) !important;
  }
  /* Gradient backdrop behind the heading/text group (for contrast) */
  .slideshow-pos--backdrop { position: relative; isolation: isolate; }
  .slideshow-pos--backdrop::before {
    content: '';
    position: absolute;
    inset: -2rem -3rem;
    z-index: -1;
    background: radial-gradient(ellipse at center, rgb(var(--backdrop-color, 0 0 0) / 0.6), rgb(var(--backdrop-color, 0 0 0) / 0) 75%);
    pointer-events: none;
  }
  .slideshow-text * { font-family: inherit; }
  .slideshow-text > * { margin: 0; }
  .slideshow-text > * + * { margin-top: var(--sp-3); }
  /* Per-block heading font (override any theme/split-words font) */
  .slideshow-pos .heading,
  .slideshow-pos .heading .word,
  .slideshow-pos .heading animate-element {
    font-family: var(--block-heading-font, var(--font-heading-family)) !important;
  }
  .slideshow-heading--custom-fs { font-size: var(--heading-fs) !important; line-height: 1.05 !important; }
  .slideshow-pos--top-left, .slideshow-pos--middle-left, .slideshow-pos--bottom-left { align-items: flex-start; text-align: left; }
  .slideshow-pos--top-center, .slideshow-pos--middle-center, .slideshow-pos--bottom-center { align-items: center; text-align: center; }
  .slideshow-pos--top-right, .slideshow-pos--middle-right, .slideshow-pos--bottom-right { align-items: flex-end; text-align: right; }
  .slideshow-pos--top-left { grid-area: top; align-self: start; justify-self: start; }
  .slideshow-pos--top-center { grid-area: top; align-self: start; justify-self: center; }
  .slideshow-pos--top-right { grid-area: top; align-self: start; justify-self: end; }
  .slideshow-pos--middle-left { grid-area: middle; align-self: center; justify-self: start; }
  .slideshow-pos--middle-center { grid-area: middle; align-self: center; justify-self: center; }
  .slideshow-pos--middle-right { grid-area: middle; align-self: center; justify-self: end; }
  .slideshow-pos--bottom-left { grid-area: bottom; align-self: end; justify-self: start; }
  .slideshow-pos--bottom-center { grid-area: bottom; align-self: end; justify-self: center; }
  .slideshow-pos--bottom-right { grid-area: bottom; align-self: end; justify-self: end; }

  /* Mobile: drop the 3x3 grid and stack the groups full-width in a single column,
     anchored to the heading's vertical zone. The grid props (grid-area / *-self)
     must be reset, or flexbox re-uses align-self and mis-aligns everything. */
  @media screen and (max-width: 767px) {
    .slideshow-word--grid {
      display: flex;
      flex-direction: column;
      gap: var(--sp-5);
      height: 100%;
    }
    .slideshow-word--v-top { justify-content: flex-start; }
    .slideshow-word--v-middle { justify-content: center; }
    .slideshow-word--v-bottom { justify-content: flex-end; }
    .slideshow-word--grid .slideshow-pos {
      grid-area: auto !important;
      align-self: stretch !important;
      justify-self: auto !important;
      width: 100%;
      max-width: 100% !important;
    }
    .slideshow-heading--custom-fs { font-size: var(--heading-fs-mobile, var(--heading-fs)) !important; }
  }
</style>

{%- if section.blocks.size > 0 -%}
{%- liquid
  assign heading_fonts = ''
  for block in section.blocks
    assign hf = block.settings.heading_font | strip
    if hf != blank
      unless heading_fonts contains hf
        assign heading_fonts = heading_fonts | append: hf | append: '|'
      endunless
    endif
  endfor
-%}
{%- if heading_fonts != blank -%}
  {%- assign hf_list = heading_fonts | split: '|' -%}
  {%- for hf in hf_list -%}{%- render 'font-loader', name: hf -%}{%- endfor -%}
{%- endif -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="{% unless section.settings.full_width %}page-width {% endunless %}relative">
    {%- if section.blocks.size > 1 and section.settings.autoplay and section.settings.show_slide_info != true -%}
      <button
        type="button"
        class="slideshow-control flex items-center justify-center rounded-full sr-only"
        is="control-button"
        aria-controls="Slider-{{ section.id }}"
        aria-live="polite"
      >
        <span class="slideshow-control__pause">
          {%- render 'icon', icon: 'pause' -%}
          <span class="sr-only">{{ 'sections.slideshow.pause_slideshow' | t }}</span>
        </span>
        <span class="slideshow-control__play">
          {%- render 'icon', icon: 'play' -%}
          <span class="sr-only">{{ 'sections.slideshow.play_slideshow' | t }}</span>
        </span>
      </button>
    {%- endif -%}
    {%- if section.settings.show_slide_info -%}
      {%- assign total = section.blocks.size -%}
      {%- capture total_padded -%}{%- if total < 10 -%}0{% endif %}{{ total }}{%- endcapture -%}
      <style>
        #shopify-section-{{ section.id }} .slideshow-info {
          padding-top: var(--sp-5);
          padding-inline-end: var(--sp-5);
          margin-left: -50px;
          color: rgb(var(--color-foreground));
          font-family: var(--font-navigation-family);
        }
        #shopify-section-{{ section.id }} .slideshow-info__count {
          font-size: 0.78rem;
          letter-spacing: 0.12em;
          font-variant-numeric: tabular-nums;
        }
        #shopify-section-{{ section.id }} .slideshow-info__control {
          flex: 0 0 auto;
          width: 2.25rem;
          height: 2.25rem;
          border: 1px solid rgb(var(--color-foreground) / 0.45);
          transition: opacity 0.2s ease;
        }
        #shopify-section-{{ section.id }} .slideshow-info__control:hover { opacity: 0.6; }
        #shopify-section-{{ section.id }} .slideshow-info__control .icon { width: 0.7rem; height: 0.7rem; }
        /* The theme's .slideshow-control:focus rule is built for the hidden a11y
           button — it resizes/repositions/recolors on focus. Neutralize it here so
           clicking this visible control never moves, resizes, or hides it. */
        #shopify-section-{{ section.id }} .slideshow-info__control:focus {
          position: static;
          width: 2.25rem;
          height: 2.25rem;
          inset: auto;
          transform: none;
          margin: 0;
          background: none;
          background-color: transparent;
          color: rgb(var(--color-foreground));
          z-index: auto;
          clip: auto;
        }
        #shopify-section-{{ section.id }} .slideshow-info__control:focus-visible {
          outline: 2px solid rgb(var(--color-foreground) / 0.5);
          outline-offset: 2px;
        }
        /* Reflect hover-pause: show the play icon while paused on hover */
        #shopify-section-{{ section.id }} .slideshow-info__control.is-hover-paused .slideshow-control__pause { display: none; }
        #shopify-section-{{ section.id }} .slideshow-info__control.is-hover-paused .slideshow-control__play { display: block; }
      </style>
      <div class="slideshow-info page-width absolute top-0 left-0 w-full z-3 flex items-center justify-end gap-3 pointer-events-none">
        <span class="slideshow-info__count" aria-hidden="true"><span data-current>01</span> / {{ total_padded }}</span>
        {%- if total > 1 and section.settings.autoplay -%}
          <button type="button" class="slideshow-info__control slideshow-control flex items-center justify-center rounded-full pointer-events-auto" is="control-button" aria-controls="Slider-{{ section.id }}" aria-live="polite">
            <span class="slideshow-control__pause">{%- render 'icon', icon: 'pause' -%}<span class="sr-only">{{ 'sections.slideshow.pause_slideshow' | t }}</span></span>
            <span class="slideshow-control__play">{%- render 'icon', icon: 'play' -%}<span class="sr-only">{{ 'sections.slideshow.play_slideshow' | t }}</span></span>
          </button>
        {%- endif -%}
      </div>
      <script>
        (function () {
          function setup() {
            var el = document.getElementById('Slider-{{ section.id }}');
            var cur = document.querySelector('#shopify-section-{{ section.id }} .slideshow-info [data-current]');
            if (!el || !cur) return false;
            function pad(n) { return n < 10 ? '0' + n : '' + n; }
            function update() { cur.textContent = pad((parseInt(el.getAttribute('selected-index')) || 0) + 1); }
            update();
            new MutationObserver(function (muts) {
              muts.forEach(function (m) { if (m.attributeName === 'selected-index') update(); });
            }).observe(el, { attributes: true, attributeFilter: ['selected-index'] });
            {%- unless section.settings.disable_hover_pause -%}
            // Hover-pause is active: mirror the paused state on the control button.
            var btn = document.querySelector('#shopify-section-{{ section.id }} .slideshow-info__control');
            if (btn) {
              el.addEventListener('mouseenter', function () { btn.classList.add('is-hover-paused'); });
              el.addEventListener('mouseleave', function () { btn.classList.remove('is-hover-paused'); });
            }
            {%- endunless -%}
            return true;
          }
          if (!setup()) {
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setup);
            else requestAnimationFrame(setup);
          }
        })();
      </script>
    {%- endif -%}
    <slideshow-element
      id="Slider-{{ section.id }}" class="slideshow block{% if section.settings.transition_direction == 'vertical' %} slideshow--vertical{% endif %}" data-direction="{{ section.settings.transition_direction }}"{% if section.settings.disable_hover_pause %} data-no-hover-pause{% endif %}{% if section.settings.autoplay %} autoplay autoplay-speed="{{ section.settings.autoplay_speed }}"{% endif %}
      role="region"
      aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
      aria-label="{{ section.settings.accessibility_info | escape }}"
    >
      {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
      {%- for block in section.blocks -%}
        {%- liquid
          if section.index == 1 and forloop.first
            assign loading = 'eager'
            assign fetchpriority = 'high'
            assign lazyimage = null
          else
            assign loading = 'lazy'
            assign fetchpriority = 'low'
            assign lazyimage = 'lazy-image'
          endif
        -%}
        {%- case block.type -%}
          {%- when 'image' -%}
            <div class="banner media--{{ section.settings.image_height }} mobile:media--{{ section.settings.image_height_mobile }} w-full overflow-hidden" data-type="image" {{ block.shopify_attributes }}>
              <media-element class="banner__media block w-full h-full overflow-hidden"{% if section.settings.enable_parallax %} data-parallax="0.3" data-parallax-dir="{{ section.settings.parallax_direction }}"{% endif %}>
                <animate-element{% if section.settings.enable_zoom %} data-animate="zoom-out"{% endif %} class="media media--height block w-full h-full relative overflow-hidden" paused>
                  <picture class="media media--height block w-full h-full relative overflow-hidden">
                    {%- if block.settings.image != blank -%}
                      {%- if block.settings.image_mobile -%}
                        <source
                          media="(max-width: 767px)"
                          srcset="{{ block.settings.image_mobile | image_url: width: '400x' }} 400w, {{ block.settings.image_mobile | image_url: width: '600x' }} 600w, {{ block.settings.image_mobile | image_url: width: '800x' }} 800w, {{ block.settings.image_mobile | image_url: width: '1000x' }} 1000w"
                          width="{{ block.settings.image_mobile.width }}"
                          height="{{ block.settings.image_mobile.height }}"
                        >
                      {%- endif -%}
    
                      {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading, fetchpriority: fetchpriority, sizes: sizes, widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200', is: lazyimage, class: 'banner__image' -}}
                    {%- else -%}
                      {%- capture placeholder -%}{% cycle 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
                      {{- placeholder | placeholder_svg_tag: 'banner__image banner__overlay placeholder' -}}
                    {%- endif -%}
                  </picture>
                </animate-element>
              </media-element>
              <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none"></span>
              {%- if block.settings.button_label == blank and block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener"{% endif %} class="block absolute top-0 left-0 w-full h-full" aria-hidden="true">&nbsp;</a>
              {%- endif -%}
            </div>

          {%- when 'video' -%}
            <div class="banner media--{{ section.settings.image_height }} mobile:media--{{ section.settings.image_height_mobile }} w-full overflow-hidden" data-type="video" {{ block.shopify_attributes }}>
              <media-element class="banner__media block w-full h-full overflow-hidden"{% if section.settings.enable_parallax %} data-parallax="0.3" data-parallax-dir="{{ section.settings.parallax_direction }}"{% endif %}>
                <animate-element{% if section.settings.enable_zoom %} data-animate="zoom-out"{% endif %} class="media media--height block w-full h-full relative overflow-hidden" paused>
                  {%- if block.settings.video_mobile or block.settings.video_url_mobile -%}
                    {%- render 'video',
                      sizes: sizes,
                      loading: loading,
                      fetchpriority: fetchpriority,
                      lazyimage: lazyimage,
                      video: block.settings.video_mobile,
                      video_url: block.settings.video_url_mobile,
                      muted: true,
                      autoplay: false,
                      loop: true,
                      description: block.settings.description,
                      cover_image: block.settings.cover_image_mobile,
                      show_play_button: false,
                      is_mobile: true,
                      class: 'banner__image'
                    -%}
                  {%- endif -%}
            
                  {%- render 'video',
                    sizes: sizes,
                    loading: loading,
                    fetchpriority: fetchpriority,
                    lazyimage: lazyimage,
                    video: block.settings.video,
                    video_url: block.settings.video_url,
                    muted: true,
                    autoplay: false,
                    loop: true,
                    description: block.settings.description,
                    cover_image: block.settings.cover_image,
                    show_play_button: false,
                    class: 'banner__image'
                  -%}
                </animate-element>
              </media-element>
              <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none"></span>
              {%- if block.settings.button_label == blank and block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener"{% endif %} class="block absolute top-0 left-0 w-full h-full" aria-hidden="true">&nbsp;</a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </slideshow-element>
    <div class="page-width absolute top-0 bottom-0 left-0 w-full pointer-events-none">
      <div class="slideshow-content flex flex-col h-full">
        <nav is="slideshow-words" class="slideshow-words grid flex-1 min-h-0" aria-controls="Slider-{{ section.id }}" aria-labelledby="Slider-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- liquid
              assign hpos = block.settings.heading_position | default: 'bottom-left'
              assign bpos = block.settings.button_position | default: 'bottom-right'
              assign hvert = hpos | split: '-' | first
              assign hwidth = block.settings.heading_width | default: 45
              assign heading_font = block.settings.heading_font
              assign heading_fs = block.settings.heading_font_size | default: 0
              assign text_font = block.settings.text_font
              assign backdrop = block.settings.text_backdrop
              assign has_heading = false
              if block.settings.heading != blank
                assign has_heading = true
              endif
              assign has_text = false
              if block.settings.text != blank
                assign has_text = true
              endif
              assign has_heading_group = false
              if has_heading or has_text
                assign has_heading_group = true
              endif
              assign has_button = false
              if block.settings.button_label != blank
                assign has_button = true
              endif
            -%}
            {%- capture heading_html -%}{%- if has_heading -%}<div class="banner__box banner__box--{{ section.settings.content_width }}"><{{ block.settings.heading_tag }} class="heading leading-none {{ block.settings.heading_size }}{% if heading_fs > 0 %} slideshow-heading--custom-fs{% endif %}" style="{% if heading_font != blank %}--block-heading-font:'{{ heading_font | strip }}',sans-serif;{% endif %}{% if heading_fs > 0 %}--heading-fs:{{ heading_fs }}px;--heading-fs-mobile:{{ heading_fs | times: 0.62 | round }}px;{% endif %}"><split-words class="split-words js-invisible block" data-animate="fade-up-large" data-animate-delay="250">{{ block.settings.heading }}</split-words></{{ block.settings.heading_tag }}></div>{%- endif -%}{%- endcapture -%}
            {%- capture text_html -%}{%- if has_text -%}{%- if text_font != blank -%}<style>{{ text_font | font_face: font_display: 'swap' }}</style>{%- endif -%}<div class="slideshow-text rte"{% if text_font != blank %} style="--block-text-font:{{ text_font.family }},{{ text_font.fallback_families }}"{% endif %} data-animate="fade-up-large" data-animate-delay="350">{{ block.settings.text }}</div>{%- endif -%}{%- endcapture -%}
            {%- capture button_color_style -%}{%- if block.settings.color_button_text != blank and block.settings.color_button_text != 'rgba(0,0,0,0)' -%}--color-button-text:{{ block.settings.color_button_text.rgb }};{%- endif -%}{%- if block.settings.color_button_background != blank and block.settings.color_button_background != 'rgba(0,0,0,0)' -%}--color-button-background:{{ block.settings.color_button_background.rgb }};--color-button-border:{{ block.settings.color_button_background.rgb }};{%- endif -%}{%- if block.settings.color_button_gradient != blank and block.settings.color_button_gradient != 'rgba(0,0,0,0)' -%}--color-button-gradient:{{ block.settings.color_button_gradient }};{%- endif -%}{%- endcapture -%}
            {%- capture button_html -%}{%- if has_button -%}{%- render 'button', label: block.settings.button_label, link: block.settings.button_link, style: block.settings.button_style, external: block.settings.button_external, show_icon: block.settings.button_icon, classes: 'button--blur button--fixed pointer-events-auto', size_style: button_color_style, shopify_attributes: block.shopify_attributes -%}{%- endif -%}{%- endcapture -%}
            {%- capture hg_open -%}<div class="slideshow-pos slideshow-pos--{{ hpos }}{% if backdrop %} slideshow-pos--backdrop{% endif %}" style="--heading-w: {{ hwidth }}cqw;{% if backdrop %}--backdrop-color:{{ block.settings.text_backdrop_color.rgb }};{% endif %}">{%- endcapture -%}
            <div class="slideshow-word slideshow-word--grid slideshow-word--v-{{ hvert }}" data-index="{{ forloop.index0 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
              {%- if has_heading_group and has_button and hpos == bpos -%}
                {{ hg_open }}{{ heading_html }}{{ text_html }}{{ button_html }}</div>
              {%- else -%}
                {%- if has_heading_group -%}{{ hg_open }}{{ heading_html }}{{ text_html }}</div>{%- endif -%}
                {%- if has_button -%}<div class="slideshow-pos slideshow-pos--{{ bpos }}">{{ button_html }}</div>{%- endif -%}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </nav>
        {%- if section.blocks.size > 1 and section.settings.show_navigation -%}
          <div class="slideshow-dots flex items-end justify-between">
            <button type="button" is="previous-button" class="hidden md:block pointer-events-auto" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.previous' | t | escape }}">
              {%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}
            </button>
            <slider-dots class="flickity-page-dots w-auto pointer-events-auto" aria-controls="Slider-{{ section.id }}">
              {%- for block in section.blocks -%}
                <button type="button" class="flickity-page-dot" data-index="{{ forloop.index0 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
                  <span class="sr-only">{{ 'general.pagination.page' | t: number: forloop.index }}</span>
                </button>
              {%- endfor -%}
            </slider-dots>
            <button type="button" is="next-button" class="hidden md:block pointer-events-auto" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.next' | t | escape }}">
              {%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}

{%- if section.settings.transition_direction == 'vertical' -%}
  <style>
    /* Seamless vertical filmstrip. Flickity runs in FADE mode (centers the
       slides on X and keeps the heading/button overlay synced via events).
       Every slide is opaque and laid out as one vertical strip (each cell
       offset by its index). A JS-appended clone of the first slide sits at the
       end so the strip can always scroll UP and reset invisibly when it reaches
       the clone. The strip is translated by a monotonic counter (--v-index). */
    #shopify-section-{{ section.id }} .slideshow--vertical .flickity-slider > * {
      opacity: 1 !important;
      transform: none !important;   /* clear fade's X offset; we center manually */
      left: 0 !important;
      right: 0 !important;
      margin-inline: auto !important;   /* center the contained banner */
    }
    {%- for i in (1..6) -%}
    #shopify-section-{{ section.id }} .slideshow--vertical .flickity-slider > *:nth-child({{ i }}) {
      top: {{ i | minus: 1 | times: 100 }}% !important;
    }
    {%- endfor -%}
    #shopify-section-{{ section.id }} .slideshow--vertical .flickity-slider {
      transform: translateY(calc(var(--v-index, 0) * -100%)) !important;
    }
    #shopify-section-{{ section.id }} .slideshow--vertical.is-ready .flickity-slider {
      transition: transform 0.9s cubic-bezier(0.65, 0, 0.35, 1) !important;
    }
  </style>
  <script>
    (function () {
      var el = document.querySelector('#Slider-{{ section.id }}.slideshow--vertical');
      if (!el) return;
      var step = 0, n = 0, slider;

      function start() {
        slider = el.querySelector('.flickity-slider');
        if (!slider || slider.children.length < 1) return false;
        n = slider.children.length;

        // Clone the first slide onto the end for a seamless upward loop.
        if (n > 1 && !slider.querySelector('[data-v-clone]')) {
          var clone = slider.children[0].cloneNode(true);
          clone.setAttribute('data-v-clone', '');
          clone.classList.remove('is-selected');
          slider.appendChild(clone);
        }

        step = parseInt(el.getAttribute('selected-index')) || 0;
        el.style.setProperty('--v-index', step);
        requestAnimationFrame(function () { el.classList.add('is-ready'); });

        // When we've scrolled onto the clone, snap back to the top with no
        // transition — invisible because the clone == the first slide.
        slider.addEventListener('transitionend', function (e) {
          if (e.propertyName !== 'transform' || step < n) return;
          el.classList.remove('is-ready');
          step = 0;
          el.style.setProperty('--v-index', 0);
          void slider.offsetHeight;           // force reflow
          el.classList.add('is-ready');
        });

        var prevIndex = parseInt(el.getAttribute('selected-index')) || 0;
        var mo = new MutationObserver(function (muts) {
          muts.forEach(function (m) {
            if (m.attributeName !== 'selected-index') return;
            var i = parseInt(el.getAttribute('selected-index')) || 0;
            if (i === prevIndex) return;
            prevIndex = i;
            step += 1;                          // always advance upward
            el.style.setProperty('--v-index', step);
          });
        });
        mo.observe(el, { attributes: true, attributeFilter: ['selected-index'] });
        return true;
      }

      if (el.classList.contains('flickity-enabled')) { start(); }
      else {
        var mo2 = new MutationObserver(function () {
          if (el.classList.contains('flickity-enabled')) { mo2.disconnect(); start(); }
        });
        mo2.observe(el, { attributes: true, attributeFilter: ['class'] });
      }
    })();
  </script>
{%- endif -%}

