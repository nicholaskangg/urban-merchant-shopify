<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    --section-grid-gap: {{ section.settings.grid_horizontal }}px;
  }
  #shopify-section-{{ section.id }} .scrolling-text__item.with-media {
    gap: 0;
  }
  #shopify-section-{{ section.id }} .scrolling-text__caption {
    margin-top: 0.85rem;
    letter-spacing: 0;
    text-transform: none;
    white-space: normal;
    max-width: var(--caption-width, none);
  }
  #shopify-section-{{ section.id }} .scrolling-text__caption-name {
    font-weight: 600;
    font-size: var(--name-size, 0.95rem);
  }
  #shopify-section-{{ section.id }} .scrolling-text__caption-address {
    font-size: var(--address-size, 0.78rem);
    opacity: 0.65;
    margin-top: 0.15rem;
  }
  #shopify-section-{{ section.id }} .scrolling-text__caption-name,
  #shopify-section-{{ section.id }} .scrolling-text__caption-name * {
    font-family: var(--name-font, inherit) !important;
  }
  #shopify-section-{{ section.id }} .scrolling-text__caption-address,
  #shopify-section-{{ section.id }} .scrolling-text__caption-address * {
    font-family: var(--address-font, inherit) !important;
  }
  #shopify-section-{{ section.id }} .is-fade-edges .scrolling-text {
    -webkit-mask-image: linear-gradient(to right, transparent, #000 var(--fade-w, 8%), #000 calc(100% - var(--fade-w, 8%)), transparent);
    mask-image: linear-gradient(to right, transparent, #000 var(--fade-w, 8%), #000 calc(100% - var(--fade-w, 8%)), transparent);
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }}.scrolling-text-section:has(.is-swipe-mobile),
    #shopify-section-{{ section.id }} .is-swipe-mobile {
      overflow: visible;
    }
    #shopify-section-{{ section.id }} .is-swipe-mobile .scrolling-text {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      touch-action: pan-x;
      overscroll-behavior-x: contain;
      scrollbar-width: none;
      width: 100%;
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .is-swipe-mobile .scrolling-text::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .is-swipe-mobile .marquee {
      animation: none !important;
    }
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}{% if section.settings.enable_twin %} section--plain{% endif %}{% if section.settings.fade_edges %} is-fade-edges{% endif %}{% if section.settings.enable_swipe_mobile %} is-swipe-mobile{% endif %}"{% if section.settings.fade_edges %} style="--fade-w: {{ section.settings.fade_width | default: 8 }}%;"{% endif %}>
  <div class="relative z-1">
    {%- if section.blocks.size > 0 -%}
      {%- capture marquee -%}
        {%- liquid
          assign first_block = section.blocks | first
          assign last_block = section.blocks | last
          if first_block.type == 'text' and last_block.type == 'text'
            assign with_dot = true
          endif

          assign with_gradient = false
          if section.settings.gradient_highlight != blank and section.settings.gradient_highlight != 'rgba(0,0,0,0)'
            assign with_gradient = true
          endif
        -%}
        <div class="marquee{% if with_dot %} with-dot{% endif %} flex items-center shrink-0 whitespace-nowrap">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                <div class="scrolling-text__item with-text flex items-center shrink-0 {{ block.settings.text_font }}{% if block.settings.text_font == 'subtitle' %} uppercase tracking-widest{% endif %} tracking-heading" style="--font-size: {{ block.settings.text_size }}px;{% if block.settings.text_size >= 100 %}--stencil-stroke-width: 0.01em;{% endif %}" {{ block.shopify_attributes }}>
                  <p>
                    {%- render 'highlighted-text', content: block.settings.text, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, gradient: with_gradient -%}
                  </p>
                </div>

              {%- when 'image' -%}
                {%- liquid
                  assign image_height = block.settings.height
                  assign image_height_2x = block.settings.height | times: 2
                -%}
                {%- capture image -%}
                  {%- if block.settings.image != blank -%}
                    <img
                      srcset="{{ block.settings.image | image_url: height: image_height }} 1x, {{ block.settings.image | image_url: height: image_height_2x }} 2x"
                      src="{{ block.settings.image | image_url: height: image_height }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      width="{{ image_height | times: block.settings.image.aspect_ratio }}"
                      height="{{ image_height }}"
                      is="lazy-image"
                    />
                  {%- else -%}
                    {{- 'logo' | placeholder_svg_tag: 'placeholder' -}}
                  {%- endif -%}
                {%- endcapture -%}

                <div class="scrolling-text__item with-media flex flex-col items-center justify-center shrink-0 media media--transparent relative" style="--image-height: {{ image_height }}px;" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a class="leading-none" href="{{ block.settings.link }}"{% if block.settings.external %} target="_blank" rel="noopener"{% endif %} aria-label="{{ block.settings.accessibility_info | escape }}">
                      {{- image -}}
                    </a>
                  {%- else -%}
                    {{- image -}}
                  {%- endif -%}
                  {%- liquid
                    assign outlet = block.settings.outlet
                    assign cafe_name = block.settings.cafe_name
                    if cafe_name == blank and outlet != blank
                      assign cafe_name = outlet.name.value
                    endif
                    assign cafe_address = block.settings.cafe_address
                    if cafe_address == blank and outlet != blank
                      assign cafe_address = outlet.address.value
                    endif
                  -%}
                  {%- if cafe_name != blank or cafe_address != blank -%}
                    {%- render 'font-loader', name: block.settings.caption_font -%}{%- render 'font-loader', name: block.settings.address_font -%}
                    <div class="scrolling-text__caption text-center leading-tight" style="{% if block.settings.caption_font != blank %}--name-font:'{{ block.settings.caption_font | strip }}',sans-serif;{% endif %}{% if block.settings.address_font != blank %}--address-font:'{{ block.settings.address_font | strip }}',sans-serif;{% endif %}--name-size:{{ block.settings.caption_size | default: 15 }}px;--address-size:{{ block.settings.address_size | default: 12 }}px;{% if block.settings.caption_width > 0 %}--caption-width:{{ block.settings.caption_width }}px;{% endif %}">
                      {%- if cafe_name != blank -%}<span class="scrolling-text__caption-name block">{{ cafe_name }}</span>{%- endif -%}
                      {%- if cafe_address != blank -%}<span class="scrolling-text__caption-address block">{{ cafe_address }}</span>{%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endcapture -%}

      {%- if section.settings.enable_twin -%}
        {%- liquid
          assign direction = section.settings.direction
          if direction == 'left'
            assign reversed = 'right'
          else
            assign reversed = 'left'
          endif
        -%}
        <div class="scrolling-wrapper with-{{ direction }} relative z-1">
          <marquee-element class="scrolling-text scrolling-text--{{ direction }} flex items-center" data-speed="{{ section.settings.speed }}" data-direction="{{ direction }}"{% if section.settings.enable_parallax %} data-parallax="1.5"{% endif %}>
            {{- marquee -}}
          </marquee-element>
        </div>
        <div class="scrolling-wrapper with-{{ direction }} relative">
          <marquee-element class="scrolling-text scrolling-text--{{ reversed }} flex items-center" data-speed="{{ section.settings.speed }}" data-direction="{{ reversed }}"{% if section.settings.enable_parallax %} data-parallax="1.5"{% endif %}>
            {{- marquee -}}
          </marquee-element>
        </div>
      {%- else -%}
        <marquee-element class="scrolling-text scrolling-text--{{ section.settings.direction }} flex items-center" data-speed="{{ section.settings.speed }}" data-direction="{{ section.settings.direction }}"{% if section.settings.enable_parallax %} data-parallax="1.5"{% endif %}>
          {{- marquee -}}
        </marquee-element>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.scrolling-text.name",
  "class": "scrolling-text-section",
  "settings": [
    {
      "type": "select",
      "id": "direction",
      "options": [
        {
          "value": "left",
          "label": "t:sections.scrolling-text.settings.direction.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.scrolling-text.settings.direction.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.scrolling-text.settings.direction.label"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "t:sections.scrolling-text.settings.speed.label",
      "unit": "x",
      "default": 20
    },
    {
      "type": "range",
      "id": "grid_horizontal",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 70,
      "unit": "px",
      "label": "t:sections.scrolling-text.settings.grid_horizontal.label"
    },
    {
      "type": "checkbox",
      "id": "enable_twin",
      "label": "t:sections.scrolling-text.settings.enable_twin.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.global.settings.enable_parallax.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_mobile",
      "label": "Allow swipe on mobile",
      "info": "On mobile, visitors can swipe through the row (auto-scroll is paused).",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "fade_edges",
      "label": "Fade into background at edges",
      "info": "Items fade into the section background as they reach the left/right edges.",
      "default": false
    },
    {
      "type": "range",
      "id": "fade_width",
      "min": 2,
      "max": 25,
      "step": 1,
      "unit": "%",
      "label": "Fade width",
      "default": 8,
      "visible_if": "{{ section.settings.fade_edges }}"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__colors.content",
      "info": "t:sections.global.settings.header__colors.info"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "t:sections.global.settings.color_text.label"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "t:sections.global.settings.color_background.label"
    },
    {
      "type": "color_background",
      "id": "gradient_background",
      "label": "t:sections.global.settings.gradient_background.label"
    },
    {
      "type": "color",
      "id": "color_highlight",
      "label": "t:sections.global.settings.color_highlight.label"
    },
    {
      "type": "color_background",
      "id": "gradient_highlight",
      "label": "t:sections.global.settings.gradient_highlight.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__section.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_bottom.label",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.global.settings.divider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "t:sections.global.settings.rounded.label"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.global.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.global.settings.text.label"
        },
        {
          "type": "range",
          "id": "text_size",
          "default": 160,
          "min": 12,
          "max": 180,
          "step": 2,
          "unit": "px",
          "label": "t:sections.global.settings.text_size.label"
        },
        {
          "type": "select",
          "id": "text_font",
          "options": [
            {
              "value": "body",
              "label": "t:sections.global.settings.text_font.options__1.label"
            },
            {
              "value": "heading",
              "label": "t:sections.global.settings.text_font.options__2.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.global.settings.text_font.options__3.label"
            }
          ],
          "default": "body",
          "label": "t:sections.global.settings.text_font.label"
        },
        {
          "type": "header",
          "content": "t:sections.global.settings.header__highlight.content",
          "info": "t:sections.global.settings.header__highlight.info"
        },
        {
          "type": "select",
          "id": "highlighted_text",
          "options": [
            {
              "value": "none",
              "label": "t:sections.global.settings.highlighted_text.options__1.label"
            },
            {
              "value": "text",
              "label": "t:sections.global.settings.highlighted_text.options__2.label"
            },
            {
              "value": "full_text",
              "label": "t:sections.global.settings.highlighted_text.options__3.label"
            },
            {
              "value": "half_text",
              "label": "t:sections.global.settings.highlighted_text.options__4.label"
            },
            {
              "value": "underline",
              "label": "t:sections.global.settings.highlighted_text.options__5.label"
            },
            {
              "value": "marker",
              "label": "t:sections.global.settings.highlighted_text.options__6.label"
            },
            {
              "value": "stencil",
              "label": "t:sections.global.settings.highlighted_text.options__7.label"
            },
            {
              "value": "scribble",
              "label": "t:sections.global.settings.highlighted_text.options__8.label"
            }
          ],
          "default": "none",
          "label": "t:sections.global.settings.highlighted_text.label"
        },
        {
          "visible_if": "{{ block.settings.highlighted_text == 'scribble' }}",
          "type": "select",
          "id": "highlighted_scribble",
          "options": [
            {
              "value": "circle",
              "label": "t:sections.global.settings.highlighted_scribble.options__1.label"
            },
            {
              "value": "basic-underline",
              "label": "t:sections.global.settings.highlighted_scribble.options__2.label"
            },
            {
              "value": "sketch-underline",
              "label": "t:sections.global.settings.highlighted_scribble.options__3.label"
            },
            {
              "value": "squiggle-underline",
              "label": "t:sections.global.settings.highlighted_scribble.options__4.label"
            },
            {
              "value": "squiggle-underline-2",
              "label": "t:sections.global.settings.highlighted_scribble.options__5.label"
            }
          ],
          "default": "circle",
          "label": "t:sections.global.settings.highlighted_scribble.label",
          "info": "t:sections.global.settings.highlighted_scribble.info"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.global.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.global.settings.image.label"
        },
        {
          "type": "metaobject",
          "id": "outlet",
          "metaobject_type": "outlet",
          "label": "Outlet (single source)",
          "info": "Link an Outlet record to auto-fill the name & address below. The fields below override it if filled."
        },
        {
          "type": "inline_richtext",
          "id": "cafe_name",
          "label": "Cafe name (header)",
          "info": "Overrides the linked Outlet's name."
        },
        {
          "type": "inline_richtext",
          "id": "cafe_address",
          "label": "Address (body)",
          "info": "Overrides the linked Outlet's address."
        },
        {
          "type": "text",
          "id": "caption_font",
          "label": "Cafe name font (Google Font)",
          "info": "Google Fonts family for the name, e.g. EB Garamond. Blank = theme font.",
          "visible_if": "{{ block.settings.cafe_name != blank }}"
        },
        {
          "type": "text",
          "id": "address_font",
          "label": "Address font (Google Font)",
          "info": "Google Fonts family for the address. Blank = theme font.",
          "visible_if": "{{ block.settings.cafe_address != blank }}"
        },
        {
          "type": "range",
          "id": "caption_size",
          "min": 10,
          "max": 48,
          "step": 1,
          "unit": "px",
          "label": "Cafe name size",
          "default": 15,
          "visible_if": "{{ block.settings.cafe_name != blank }}"
        },
        {
          "type": "range",
          "id": "address_size",
          "min": 8,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Address size",
          "default": 12,
          "visible_if": "{{ block.settings.cafe_address != blank }}"
        },
        {
          "type": "range",
          "id": "caption_width",
          "min": 0,
          "max": 400,
          "step": 10,
          "unit": "px",
          "label": "Caption max width",
          "info": "0 = single line. Set a width to wrap long addresses.",
          "default": 0,
          "visible_if": "{{ block.settings.cafe_name != blank or block.settings.cafe_address != blank }}"
        },
        {
          "type": "range",
          "id": "height",
          "min": 0,
          "max": 200,
          "step": 4,
          "default": 80,
          "unit": "px",
          "label": "t:sections.scrolling-text.blocks.image.settings.image_height.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.global.settings.link.label"
        },
        {
          "type": "text",
          "id": "accessibility_info",
          "label": "t:sections.global.settings.accessibility.label",
          "info": "t:sections.global.settings.accessibility.info",
          "visible_if": "{{ block.settings.link != blank }}"
        },
        {
          "type": "checkbox",
          "id": "external",
          "label": "t:sections.global.settings.button_external.label",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.scrolling-text.name",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "text"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "custom.overlay"
    ]
  }
}
{% endschema %}
