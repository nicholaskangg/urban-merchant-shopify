<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --outlets-cols: {{ section.settings.columns }};
    {%- render 'section-variables', section: section -%}
  }
  #shopify-section-{{ section.id }} .outlets {
    display: grid;
    grid-template-columns: repeat(var(--outlets-cols), minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .outlets { grid-template-columns: 1fr; gap: 3rem; }
  }
  #shopify-section-{{ section.id }} .outlet { display: flex; flex-direction: column; }

  /* Media + hover swap */
  #shopify-section-{{ section.id }} .outlet__media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: var(--outlet-ratio, 4 / 3);
    background: rgb(var(--color-foreground) / 0.05);
  }
  #shopify-section-{{ section.id }} .outlet__media--adapt { aspect-ratio: auto; }
  #shopify-section-{{ section.id }} .outlet__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
  }
  #shopify-section-{{ section.id }} .outlet__img--hover {
    opacity: 0;
    transition: opacity 0.55s ease;
  }
  #shopify-section-{{ section.id }} .outlet__media:hover .outlet__img--hover,
  #shopify-section-{{ section.id }} .outlet__media:focus-within .outlet__img--hover {
    opacity: 1;
  }

  /* Body */
  #shopify-section-{{ section.id }} .outlet__body { margin-top: 1.5rem; display: flex; flex-direction: column; }
  #shopify-section-{{ section.id }} .outlet__name {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.05rem, 1.4vw, 1.35rem);
    line-height: 1.1;
  }
  #shopify-section-{{ section.id }} .outlet__desc {
    margin-top: 0.85rem;
    font-size: 1rem;
    line-height: 1.45;
    opacity: 0.9;
  }
  /* Manual richtext and metaobject rich_text both render inside .metafield-rich_text_field
     so they share the metafield's natural .rte paragraph spacing. */
  #shopify-section-{{ section.id }} .outlet__desc .metafield-rich_text_field { margin: 0; }

  /* Address */
  #shopify-section-{{ section.id }} .outlet__address {
    margin-top: 1.1rem;
    font-size: 0.85rem;
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} .outlet__address-text { display: block; opacity: 0.8; }
  #shopify-section-{{ section.id }} .outlet__address-actions {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  #shopify-section-{{ section.id }} .outlet__action {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    background: none;
    border: 0;
    padding: 0;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  #shopify-section-{{ section.id }} .outlet__action:hover { opacity: 0.6; }
  #shopify-section-{{ section.id }} .outlet__action svg { width: 1rem; height: 1rem; flex-shrink: 0; }
  #shopify-section-{{ section.id }} copy-text.is-copied { opacity: 0.6; }

  /* Buttons */
  #shopify-section-{{ section.id }} .outlet__buttons {
    margin-top: auto;
    padding-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  #shopify-section-{{ section.id }} .outlet__buttons .button { margin: 0; }
</style>

{%- if section.blocks.size > 0 -%}
  <div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
    <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag | default: 'h2' }} class="heading {{ section.settings.heading_size }} mb-8">{{ section.settings.heading }}</{{ section.settings.heading_tag | default: 'h2' }}>
      {%- endif -%}

      <div class="outlets">
        {%- for block in section.blocks -%}
          {%- liquid
            assign outlet = block.settings.outlet

            # Each field: manual block setting wins, otherwise pull from the linked Outlet metaobject
            assign name = block.settings.name
            if name == blank and outlet != blank
              assign name = outlet.name.value
            endif

            assign address = block.settings.address
            if address == blank and outlet != blank
              assign address = outlet.address.value
            endif

            assign image = block.settings.image
            if image == blank and outlet != blank
              assign image = outlet.primary_image.value
            endif
            if image == blank and outlet != blank
              assign image = outlet.logo.value
            endif

            assign image_hover = block.settings.image_hover
            if image_hover == blank and outlet != blank
              assign image_hover = outlet.secondary_image.value
            endif

            assign collection = block.settings.collection
            if collection == blank and outlet != blank
              assign collection = outlet.collection.value
            endif

            assign concept = block.settings.concept_link
            if concept == blank and outlet != blank
              assign concept = outlet.system.url
            endif

            assign maps_url = block.settings.map_url
            if maps_url == blank and outlet != blank
              assign maps_url = outlet.maps_url.value
            endif
            if maps_url == blank and address != blank
              assign enc = address | strip_newlines | url_encode
              assign maps_url = 'https://www.google.com/maps/search/?api=1&query=' | append: enc
            endif

            assign ratio_class = ''
            if section.settings.image_ratio == 'adapt'
              assign ratio_class = ' outlet__media--adapt'
            endif
          -%}

          <div class="outlet"
            {% if section.settings.image_ratio == 'square' %}style="--outlet-ratio: 1 / 1;"{% elsif section.settings.image_ratio == 'landscape' %}style="--outlet-ratio: 4 / 3;"{% elsif section.settings.image_ratio == 'portrait' %}style="--outlet-ratio: 3 / 4;"{% elsif section.settings.image_ratio == 'wide' %}style="--outlet-ratio: 3 / 2;"{% endif %}
            {{ block.shopify_attributes }}>

            {%- if concept != blank -%}
              <a class="outlet__media{{ ratio_class }}" href="{{ concept }}" aria-label="{{ name | default: 'Outlet' | escape }}">
            {%- else -%}
              <div class="outlet__media{{ ratio_class }}">
            {%- endif -%}
              {%- if image != blank -%}
                {{ image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '400,600,800,1000,1200,1400', sizes: '(min-width: 768px) 50vw, 100vw', is: 'lazy-image', class: 'outlet__img outlet__img--primary' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder outlet__img outlet__img--primary' }}
              {%- endif -%}
              {%- if image_hover != blank -%}
                {{ image_hover | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '400,600,800,1000,1200,1400', sizes: '(min-width: 768px) 50vw, 100vw', is: 'lazy-image', class: 'outlet__img outlet__img--hover' }}
              {%- endif -%}
            {%- if concept != blank -%}</a>{%- else -%}</div>{%- endif -%}

            <div class="outlet__body">
              {%- if name != blank -%}
                <{{ block.settings.name_tag | default: 'h3' }} class="outlet__name">{{ name }}</{{ block.settings.name_tag | default: 'h3' }}>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <div class="outlet__desc rte"><div class="metafield-rich_text_field">{{ block.settings.description }}</div></div>
              {%- elsif outlet != blank and outlet.description != blank -%}
                <div class="outlet__desc rte">{{ outlet.description | metafield_tag }}</div>
              {%- endif -%}

              {%- if address != blank -%}
                <div class="outlet__address">
                  <span class="outlet__address-text">{{ address }}</span>
                  <div class="outlet__address-actions">
                    <copy-text class="outlet__action" data-text="{{ address | strip_newlines | escape }}" role="button" tabindex="0">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                      <span class="outlet__action-label" data-copy="{{ section.settings.copy_label | default: 'Copy address' | escape }}" data-copied="{{ section.settings.copied_label | default: 'Copied!' | escape }}">{{ section.settings.copy_label | default: 'Copy address' }}</span>
                    </copy-text>
                    {%- if maps_url != blank -%}
                      <a class="outlet__action" href="{{ maps_url }}" target="_blank" rel="noopener" aria-label="Open in Google Maps">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <span>{{ section.settings.map_label | default: 'Directions' }}</span>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

              {%- if concept != blank or collection != blank -%}
                <div class="outlet__buttons">
                  {%- if concept != blank -%}
                    <a class="button button--primary" href="{{ concept }}">{{ section.settings.concept_label | default: 'View concept' }}</a>
                  {%- endif -%}
                  {%- if collection != blank -%}
                    <a class="button button--secondary" href="{{ collection.url }}">{{ section.settings.shop_label | default: 'Shop collection' }}</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

<script>
  if (!customElements.get('copy-text')) {
    customElements.define('copy-text', class extends HTMLElement {
      connectedCallback() {
        this.addEventListener('click', () => this.copy());
        this.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.copy(); }
        });
      }
      copy() {
        const text = this.getAttribute('data-text');
        if (!text) return;
        const done = () => {
          this.classList.add('is-copied');
          const label = this.querySelector('.outlet__action-label');
          if (label && label.dataset.copied) {
            const original = label.dataset.copy || label.textContent;
            label.textContent = label.dataset.copied;
            setTimeout(() => { label.textContent = original; this.classList.remove('is-copied'); }, 1500);
          } else {
            setTimeout(() => this.classList.remove('is-copied'), 1500);
          }
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done).catch(() => this.fallback(text, done));
        } else {
          this.fallback(text, done);
        }
      }
      fallback(text, done) {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); done(); } catch (e) {}
        document.body.removeChild(ta);
      }
    });
  }
</script>

{% schema %}
{
